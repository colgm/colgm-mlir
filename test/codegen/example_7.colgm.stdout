module {
  func.func @main() -> tensor<i64> {
    %0 = colgm.constant dense<0> : tensor<i64> loc(#loc1)
    %1 = colgm.constant dense<1> : tensor<i64> loc(#loc2)
    %2 = colgm.constant dense<2> : tensor<i64> loc(#loc3)
    %3 = colgm.constant dense<3> : tensor<i64> loc(#loc4)
    %4 = colgm.elements(%0, %1, %2, %3) {target_shape = [4]} : tensor<i64> -> tensor<4xi64> loc(#loc5)
    %5 = colgm.constant dense<0> : tensor<i64> loc(#loc6)
    %6 = colgm.cast %5 : tensor<i64> -> index loc(#loc6)
    %7 = colgm.slice %4, %6 {axis = 0} : tensor<4xi64>, index -> tensor<i64> loc(#loc7)
    %8 = colgm.constant dense<0> : tensor<i64> loc(#loc8)
    %9 = colgm.cmp_gt %7, %8 : tensor<i64> -> tensor<i1> loc(#loc9)
    %10 = colgm.cast %9 : tensor<i1> -> i1 loc(#loc10)
    %11 = colgm.if %10 -> tensor<i64> {
      %12 = colgm.constant dense<1> : tensor<i64> loc(#loc11)
      %13 = colgm.neg %12 : tensor<i64> loc(#loc12)
      colgm.yield %13 : tensor<i64> loc(#loc13)
    } else {
      %12 = colgm.constant dense<0> : tensor<i64> loc(#loc14)
      colgm.yield %12 : tensor<i64> loc(#loc15)
    } loc(#loc10)
    return %11 : tensor<i64> loc(#loc16)
  } loc(#loc)
} loc(#loc)

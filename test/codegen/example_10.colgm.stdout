module {
  func.func @main() -> tensor<i64> {
    %0 = colgm.constant dense<0> : tensor<i64> loc(#loc1)
    %1 = colgm.constant dense<1> : tensor<i64> loc(#loc2)
    %2 = colgm.constant dense<2> : tensor<i64> loc(#loc3)
    %3 = colgm.constant dense<3> : tensor<i64> loc(#loc4)
    %4 = colgm.elements(%0, %1, %2, %3) {target_shape = [4]} : tensor<i64> -> tensor<4xi64> loc(#loc5)
    %5 = colgm.constant dense<1> : tensor<i64> loc(#loc6)
    %6 = colgm.neg %5 : tensor<i64> loc(#loc7)
    %7 = colgm.constant dense<0> : tensor<i64> loc(#loc8)
    %8 = colgm.constant dense<0> : tensor<i64> loc(#loc9)
    %9 = colgm.constant dense<4> : tensor<i64> loc(#loc10)
    %10 = colgm.cast %8 : tensor<i64> -> index loc(#loc11)

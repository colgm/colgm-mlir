func main() {
    var a = 3
    var b = 5
    var ceq = a == b    // i64 cmp_eq
    var cne = a != b    // i64 cmp_ne
    var clt = a < b     // i64 cmp_lt
    var cle = a <= b    // i64 cmp_le
    var cgt = a > b     // i64 cmp_gt
    var cge = a >= b    // i64 cmp_ge

    var x = 1.5
    var y = 3.5
    var feq = x == y    // f64 cmp_eq
    var fne = x != y    // f64 cmp_ne
    var flt = x < y     // f64 cmp_lt
    var fle = x <= y    // f64 cmp_le
    var fgt = x > y     // f64 cmp_gt
    var fge = x >= y    // f64 cmp_ge

    var v1 = [1, 2, 3]
    var v2 = [3, 2, 1]
    var r1 = v1 < v2     // tensor<3xi64> cmp_lt
    var w1 = [1.0, 2.0, 3.0]
    var w2 = [3.0, 2.0, 1.0]
    var r2 = w1 > w2     // tensor<3xf64> cmp_gt
}

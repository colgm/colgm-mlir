module {
  func.func @main() {
    %cst = arith.constant dense<6> : tensor<i64> loc(#loc1)
    %cst_0 = arith.constant dense<2> : tensor<i64> loc(#loc2)
    %0 = arith.divsi %cst, %cst_0 : tensor<i64> loc(#loc3)
    %cst_1 = arith.constant dense<6.000000e+00> : tensor<f64> loc(#loc4)
    %cst_2 = arith.constant dense<2.000000e+00> : tensor<f64> loc(#loc5)
    %1 = arith.divf %cst_1, %cst_2 : tensor<f64> loc(#loc6)
    %cst_3 = arith.constant dense<[6, 4, 2]> : tensor<3xi64> loc(#loc7)
    %cst_4 = arith.constant dense<2> : tensor<3xi64> loc(#loc8)
    %2 = arith.divsi %cst_3, %cst_4 : tensor<3xi64> loc(#loc9)
    %cst_5 = arith.constant dense<[6.000000e+00, 4.000000e+00, 2.000000e+00]> : tensor<3xf64> loc(#loc10)
    %cst_6 = arith.constant dense<2.000000e+00> : tensor<3xf64> loc(#loc11)
    %3 = arith.divf %cst_5, %cst_6 : tensor<3xf64> loc(#loc12)
    %cst_7 = arith.constant dense<[[6, 4], [2, 0]]> : tensor<2x2xi64> loc(#loc13)
    %cst_8 = arith.constant dense<2> : tensor<2x2xi64> loc(#loc14)
    %4 = arith.divsi %cst_7, %cst_8 : tensor<2x2xi64> loc(#loc15)
    %cst_9 = arith.constant dense<[[6.000000e+00, 4.000000e+00], [2.000000e+00, 0.000000e+00]]> : tensor<2x2xf64> loc(#loc16)
    %cst_10 = arith.constant dense<2.000000e+00> : tensor<2x2xf64> loc(#loc17)
    %5 = arith.divf %cst_9, %cst_10 : tensor<2x2xf64> loc(#loc18)
    return loc(#loc)
  } loc(#loc)
} loc(#loc)

module {
  func.func @main() {
    %cst = arith.constant dense<1> : tensor<i64> loc(#loc1)
    %0 = arith.addi %cst, %cst : tensor<i64> loc(#loc2)
    %cst_0 = arith.constant dense<1.200000e+00> : tensor<f64> loc(#loc3)
    %1 = arith.addf %cst_0, %cst_0 : tensor<f64> loc(#loc4)
    %cst_1 = arith.constant dense<[1, 2, 3]> : tensor<3xi64> loc(#loc5)
    %2 = arith.addi %cst_1, %cst_1 : tensor<3xi64> loc(#loc6)
    %cst_2 = arith.constant dense<[1.200000e+00, 2.300000e+00, 3.400000e+00]> : tensor<3xf64> loc(#loc7)
    %3 = arith.addf %cst_2, %cst_2 : tensor<3xf64> loc(#loc8)
    %cst_3 = arith.constant dense<[[1, 2], [3, 4]]> : tensor<2x2xi64> loc(#loc9)
    %4 = arith.addi %cst_3, %cst_3 : tensor<2x2xi64> loc(#loc10)
    %cst_4 = arith.constant dense<[[1.200000e+00, 2.300000e+00], [3.400000e+00, 4.500000e+00]]> : tensor<2x2xf64> loc(#loc11)
    %5 = arith.addf %cst_4, %cst_4 : tensor<2x2xf64> loc(#loc12)
    return loc(#loc)
  } loc(#loc)
} loc(#loc)

module {
  func.func @main() {
    %cst = arith.constant dense<[1.000000e-01, 2.000000e-01, 0.30000000000000004]> : tensor<3xf64> loc(#loc1)
    %cst_0 = arith.constant dense<0.000000e+00> : tensor<f64> loc(#loc2)
    %cst_1 = arith.constant dense<0.60000000000000009> : tensor<f64> loc(#loc3)
    %cst_2 = arith.constant dense<0> : tensor<i64> loc(#loc4)
    %cst_3 = arith.constant dense<2> : tensor<i64> loc(#loc5)
    %extracted = tensor.extract %cst_2[] : tensor<i64> loc(#loc6)
    %0 = arith.index_cast %extracted : i64 to index loc(#loc6)
    %extracted_4 = tensor.extract %cst_3[] : tensor<i64> loc(#loc6)
    %1 = arith.index_cast %extracted_4 : i64 to index loc(#loc6)
    %c1 = arith.constant 1 : index loc(#loc6)
    %2:2 = scf.for %arg0 = %0 to %1 step %c1 iter_args(%arg1 = %cst_0, %arg2 = %cst_1) -> (tensor<f64>, tensor<f64>) {
      %extracted_slice = tensor.extract_slice %cst[%arg0] [1] [1] : tensor<3xf64> to tensor<f64> loc(#loc7)
      %3 = arith.addf %arg1, %extracted_slice : tensor<f64> loc(#loc8)
      %extracted_slice_5 = tensor.extract_slice %cst[%arg0] [1] [1] : tensor<3xf64> to tensor<f64> loc(#loc9)
      %4 = arith.subf %arg2, %extracted_slice_5 : tensor<f64> loc(#loc10)
      scf.yield %3, %4 : tensor<f64>, tensor<f64> loc(#loc11)
    } loc(#loc6)
    return loc(#loc)
  } loc(#loc)
} loc(#loc)

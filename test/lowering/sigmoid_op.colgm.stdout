module {
  func.func @main() {
    %cst = arith.constant dense<[1.000000e+00, 2.000000e+00, 3.000000e+00]> : tensor<3xf64> loc(#loc1)
    %cst_0 = arith.constant dense<0.000000e+00> : tensor<3xf64> loc(#loc2)
    %cst_1 = arith.constant dense<1.000000e+00> : tensor<3xf64> loc(#loc2)
    %0 = arith.subf %cst_0, %cst : tensor<3xf64> loc(#loc2)
    %1 = math.exp %0 : tensor<3xf64> loc(#loc2)
    %2 = arith.addf %cst_1, %1 : tensor<3xf64> loc(#loc2)
    %3 = arith.divf %cst_1, %2 : tensor<3xf64> loc(#loc2)
    return loc(#loc)
  } loc(#loc)
} loc(#loc)

func main() {
    var a = 3
    var b = a * 2
    var c = 3.5
    var d = c * 2.0

    var x = [1, 2, 3]
    var y = x * [2, 2, 2]
    var z = [1.5, 2.5, 3.5]
    var w = z * [2.0, 2.0, 2.0]

    var foo = [[1, 2], [3, 4]]

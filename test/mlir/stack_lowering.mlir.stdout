module {
  func.func @test_stack_1d_to_2d(%arg0: tensor<4xf32>, %arg1: tensor<4xf32>, %arg2: tensor<4xf32>) -> tensor<3x4xf32> {
    %0 = tensor.empty() : tensor<3x4xf32>
    %cst = arith.constant dense<[1, 4]> : tensor<2xindex>
    %reshape = tensor.reshape %arg0(%cst) : (tensor<4xf32>, tensor<2xindex>) -> tensor<1x4xf32>
    %inserted_slice = tensor.insert_slice %reshape into %0[0, 0] [1, 4] [1, 1] : tensor<1x4xf32> into tensor<3x4xf32>
    %cst_0 = arith.constant dense<[1, 4]> : tensor<2xindex>
    %reshape_1 = tensor.reshape %arg1(%cst_0) : (tensor<4xf32>, tensor<2xindex>) -> tensor<1x4xf32>
    %inserted_slice_2 = tensor.insert_slice %reshape_1 into %inserted_slice[1, 0] [1, 4] [1, 1] : tensor<1x4xf32> into tensor<3x4xf32>
    %cst_3 = arith.constant dense<[1, 4]> : tensor<2xindex>
    %reshape_4 = tensor.reshape %arg2(%cst_3) : (tensor<4xf32>, tensor<2xindex>) -> tensor<1x4xf32>
    %inserted_slice_5 = tensor.insert_slice %reshape_4 into %inserted_slice_2[2, 0] [1, 4] [1, 1] : tensor<1x4xf32> into tensor<3x4xf32>
    return %inserted_slice_5 : tensor<3x4xf32>
  }
  func.func @test_stack_2d_to_3d(%arg0: tensor<2x4xi64>, %arg1: tensor<2x4xi64>) -> tensor<2x2x4xi64> {
    %0 = tensor.empty() : tensor<2x2x4xi64>
    %cst = arith.constant dense<[1, 2, 4]> : tensor<3xindex>
    %reshape = tensor.reshape %arg0(%cst) : (tensor<2x4xi64>, tensor<3xindex>) -> tensor<1x2x4xi64>
    %inserted_slice = tensor.insert_slice %reshape into %0[0, 0, 0] [1, 2, 4] [1, 1, 1] : tensor<1x2x4xi64> into tensor<2x2x4xi64>
    %cst_0 = arith.constant dense<[1, 2, 4]> : tensor<3xindex>
    %reshape_1 = tensor.reshape %arg1(%cst_0) : (tensor<2x4xi64>, tensor<3xindex>) -> tensor<1x2x4xi64>
    %inserted_slice_2 = tensor.insert_slice %reshape_1 into %inserted_slice[1, 0, 0] [1, 2, 4] [1, 1, 1] : tensor<1x2x4xi64> into tensor<2x2x4xi64>
    return %inserted_slice_2 : tensor<2x2x4xi64>
  }
}


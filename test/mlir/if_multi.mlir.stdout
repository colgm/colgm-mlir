module {
  func.func @if_two_results(%arg0: i1, %arg1: tensor<f32>, %arg2: tensor<f32>) -> (tensor<f32>, tensor<f32>) {
    %0:2 = colgm.if %arg0 -> (tensor<f32>, tensor<f32>) {
      colgm.yield %arg1, %arg2 : tensor<f32>, tensor<f32>
    } else {
      colgm.yield %arg2, %arg1 : tensor<f32>, tensor<f32>
    }
    return %0#0, %0#1 : tensor<f32>, tensor<f32>
  }
  func.func @if_three_results(%arg0: i1, %arg1: tensor<f32>, %arg2: tensor<f32>) -> (tensor<f32>, tensor<f32>, tensor<f32>) {
    %0:3 = colgm.if %arg0 -> (tensor<f32>, tensor<f32>, tensor<f32>) {
      %1 = colgm.add %arg1, %arg2 : tensor<f32>
      %2 = colgm.sub %arg1, %arg2 : tensor<f32>
      %3 = colgm.mul %arg1, %arg2 : tensor<f32>
      colgm.yield %1, %2, %3 : tensor<f32>, tensor<f32>, tensor<f32>
    } else {
      colgm.yield %arg1, %arg2, %arg1 : tensor<f32>, tensor<f32>, tensor<f32>
    }
    return %0#0, %0#1, %0#2 : tensor<f32>, tensor<f32>, tensor<f32>
  }
  func.func @if_mixed_types(%arg0: i1) -> (tensor<f32>, tensor<i32>) {
    %0 = colgm.constant dense<1.000000e+00> : tensor<f32>
    %1 = colgm.constant dense<42> : tensor<i32>
    %2 = colgm.constant dense<3.000000e+00> : tensor<f32>
    %3 = colgm.constant dense<99> : tensor<i32>
    %4:2 = colgm.if %arg0 -> (tensor<f32>, tensor<i32>) {
      colgm.yield %0, %1 : tensor<f32>, tensor<i32>
    } else {
      colgm.yield %2, %3 : tensor<f32>, tensor<i32>
    }
    return %4#0, %4#1 : tensor<f32>, tensor<i32>
  }
}

